# 오봇 (O-Bot) - Opinion.trade 전용. 복사 후 .env 로 저장하고 값을 채우세요.

# 계정 1 (Wallet 1)
OPINION_API_KEY=your_opinion_api_key
OPINION_PROXY=IP:PORT:USER:PASS
OPINION_DEFAULT_EOA=0x...

# 계정 2 (Wallet 2)
OPINION_API_KEY_2=
OPINION_PROXY_2=IP:PORT:USER:PASS
OPINION_EOA_2=0x...

# 계정 3 이상: OPINION_EOA_3, OPINION_API_KEY_3, OPINION_PROXY_3 ... 순서로 추가 (최대 20개)
# OPINION_EOA_3=0x...
# OPINION_API_KEY_3=
# OPINION_PROXY_3=IP:PORT:USER:PASS

# OKX Wallet BNB Chain PK (자전거래 시 필요. 64자 hex, 0x 선택) — 계정 N → OPINION_CLOB_PK_N
OPINION_CLOB_PK_1=
OPINION_CLOB_PK_2=

# Gnosis Safe 컨트랙트 주소 (CLOB 주문 시 필수. EOA가 아닌 Safe 프록시 주소)
# Opinion.trade는 자산(USDT·토큰)을 Gnosis Safe에 보관. multi_sig_addr로 이 주소를 사용해야 에러 10603 방지.
# 확인 방법: safe.global → BNB Chain → 내 지갑 연결 후 Safe 주소 복사
#            또는 BSCscan에서 내 지갑 트랜잭션 내역에서 GnosisSafeProxy 생성 확인
OPINION_MULTISIG_1=0x...
OPINION_MULTISIG_2=0x...

OPINION_CLOB_HOST=https://proxy.opinion.trade:8443
BSC_RPC_URL=https://bsc-dataseed.binance.org/
# BSC RPC 실패 시 자동으로 시도할 대체 URL (쉼표 구분). 비우면 기본 목록 사용
# BSC_RPC_FALLBACKS=https://bsc-dataseed1.binance.org/,https://rpc.ankr.com/bsc
# BSC RPC를 Opinion 프록시로 나가게 함 (서버에서 RPC 막혀 있을 때). 끄려면 BSC_RPC_USE_PROXY=0
# BSC_RPC_USE_PROXY=1

PYTH_API_URL=https://hermes.pyth.network/api/latest_price_feeds
BTC_PRICE_FEED_ID=0xe62df6c8b4a85fe1a67db44dc12de5db330f7ac66b72dc658afedf0f4a415b43

MIN_PRICE_GAP=200
TIME_BEFORE_END=300

# 잔고 조회 실패 시에도 거래 진행 (BSC/OKX 접속 안 될 때만 1로 설정)
# SKIP_BALANCE_CHECK=1

SECRET_KEY=your_secret_key_change_in_production
FLASK_ENV=development
FLASK_DEBUG=True
